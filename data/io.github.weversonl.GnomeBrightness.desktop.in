[Desktop Entry]
Type=Application
Name=GnomeBrightness
GenericName=Brightness Control
GenericName[pt_BR]=Controle de Brilho
Comment=Control external monitor brightness over DDC/CI
Comment[pt_BR]=Controla o brilho dos monitores via DDC/CI
Exec=@BINDIR@/gnome-brightness
Icon=io.github.weversonl.GnomeBrightness
Terminal=false
Categories=GTK;Utility;Settings;
StartupNotify=true
X-GNOME-UsesNotifications=false
